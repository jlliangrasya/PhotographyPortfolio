---
---

<section class="relative min-h-screen flex items-center justify-center bg-navy-900 overflow-hidden">
  <!-- Radial gradient background -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(17,29,66,0.8)_0%,_rgba(10,15,30,1)_70%)]"></div>

  <!-- AF Monogram watermark -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none">
    <span class="text-[20rem] md:text-[28rem] font-heading font-bold text-white/[0.03] leading-none">
      AF
    </span>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <!-- Badge -->
    <div data-aos="fade-down" class="inline-flex items-center gap-2 bg-navy-700/60 border border-silver-300/20 rounded-full px-5 py-2 mb-8">
      <span class="text-sm text-silver-300 tracking-wide">Southern Leyte &middot; Serving Nationwide</span>
    </div>

    <!-- Heading -->
    <h1 data-aos="fade-up" data-aos-delay="100" class="font-heading text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-tight mb-6">
      We Shoot First,<br />Ask Questions Later.
    </h1>

    <!-- Subheading -->
    <p data-aos="fade-up" data-aos-delay="200" class="text-lg md:text-xl text-silver-300 mb-10 tracking-wide">
      Wedding &middot; Portrait &middot; Events &middot; Commercial Photography
    </p>

    <!-- CTA Buttons -->
    <div data-aos="fade-up" data-aos-delay="300" class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#booking"
        class="bg-silver-100 text-navy-900 px-8 py-3 rounded-full font-semibold text-base hover:bg-accent transition-colors"
      >
        Book a Session
      </a>
      <a
        href="#gallery"
        class="border border-silver-300 text-silver-100 px-8 py-3 rounded-full font-semibold text-base hover:bg-silver-100 hover:text-navy-900 transition-all"
      >
        View Our Work
      </a>
    </div>
  </div>

  <!-- Scroll down arrow -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <a href="#about" class="text-silver-500 hover:text-silver-100 transition-colors" aria-label="Scroll down">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </a>
  </div>
</section>
