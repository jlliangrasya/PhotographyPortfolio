---
const services = [
  {
    title: "Weddings",
    description: "From vows to reception, we capture every tear, laugh, and dance.",
    icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />`,
    delay: 0,
  },
  {
    title: "Portraits",
    description: "Personal or professional, we make sure you look your absolute best.",
    icon: `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" />`,
    delay: 100,
  },
  {
    title: "Events",
    description: "Birthdays, debuts, corporate — if it matters to you, it matters to us.",
    icon: `<rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" />`,
    delay: 200,
  },
  {
    title: "Commercial / Brand",
    description: "Elevate your brand with imagery that speaks louder than words.",
    icon: `<rect x="2" y="7" width="20" height="14" rx="2" ry="2" /><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />`,
    delay: 300,
  },
];
---

<section id="services" class="py-20 md:py-28 bg-navy-900">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Heading -->
    <h2 data-aos="fade-up" class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-white text-center mb-16">
      What We Do
    </h2>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 gap-6 lg:gap-8">
      {services.map((service) => (
        <div
          data-aos="fade-up"
          data-aos-delay={service.delay}
          class="group bg-navy-700 rounded-2xl p-6 lg:p-8 border-t-2 border-silver-300/20 hover:shadow-[0_0_30px_rgba(192,192,192,0.1)] transition-all duration-300"
        >
          <!-- Icon -->
          <div class="w-12 h-12 mb-5 text-accent">
            <svg
              class="w-full h-full"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              viewBox="0 0 24 24"
            >
              <Fragment set:html={service.icon} />
            </svg>
          </div>

          <h3 class="font-heading text-xl lg:text-2xl font-bold text-white mb-3">{service.title}</h3>
          <p class="text-silver-300 leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
