---
import { testimonials } from '../data/testimonials.js';

// Duplicate for infinite scroll effect
const doubledTestimonials = [...testimonials, ...testimonials];
---

<section id="testimonials" class="py-20 md:py-28 bg-navy-900 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Heading -->
    <h2 data-aos="fade-up" class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-white text-center mb-16">
      What Our Clients Say
    </h2>
  </div>

  <!-- Marquee Container -->
  <div data-aos="fade-up" data-aos-delay="200" class="relative">
    <!-- Gradient overlays -->
    <div class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-navy-900 to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-navy-900 to-transparent z-10 pointer-events-none"></div>

    <!-- Scrolling track -->
    <div class="animate-marquee flex gap-6 w-max">
      {doubledTestimonials.map((t) => (
        <div class="flex-shrink-0 w-80 bg-navy-700 rounded-2xl p-6 border border-silver-300/10">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-silver-100 leading-relaxed mb-4 italic">"{t.quote}"</p>

          <!-- Client info -->
          <div>
            <p class="text-white font-semibold">{t.name}</p>
            <p class="text-accent text-sm">{t.service}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
